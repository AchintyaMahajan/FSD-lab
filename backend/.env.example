# ============================================================
# MasterMail - Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/mastermail
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/mastermail
MONGO_URL=mongodb://localhost:27017/mastermail
DB_NAME=mastermail

# ── Google OAuth 2.0 ─────────────────────────────────────────
# Obtain from Google Cloud Console → APIs & Services → Credentials
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Google Gemini AI ─────────────────────────────────────────
# Each user provides their own key, but the server uses this as default.
# Obtain from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Session ──────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_32_char_random_string_here

# ── Server ───────────────────────────────────────────────────
PORT=8001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────
# URL of the React frontend (used for CORS allow-origin)
FRONTEND_URL=http://localhost:3000
