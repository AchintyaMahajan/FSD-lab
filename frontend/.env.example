# ============================================================
# MasterMail - Frontend Environment Variables (Vite)
# ============================================================
# In Vite all public env vars MUST start with VITE_
# Rename this file to .env and fill in your real values.
# ============================================================

# URL of the running backend server
VITE_BACKEND_URL=http://localhost:8001

# Same Google OAuth Client ID used in the backend
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
